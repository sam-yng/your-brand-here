{
  "name": "your-brand-here",
  "description": "Independent web studio and self-directed design portfolio.",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "format": "biome format --write .",
    "format:check": "biome ci --linter-enabled=false --assist-enabled=false .",
    "lint": "biome ci --formatter-enabled=false --assist-enabled=false .",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "bun test tests/unit",
    "test:e2e": "bun run build && playwright test",
    "plan:check": "node .agents/scripts/check-plan-lifecycle.mjs",
    "guard:tests": "node .agents/guardrails/check-test-integrity.mjs",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run build && bun run test:e2e && bun run guard:tests && bun run plan:check"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "2.5.3",
    "@playwright/test": "^1.60.0",
    "@samyng/h-alter": "^0.4.0",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.14",
    "lefthook": "^1.13.6",
    "nano-staged": "^1.0.2",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "resend": "^6.17.2",
    "zod": "^4.4.3"
  }
}
